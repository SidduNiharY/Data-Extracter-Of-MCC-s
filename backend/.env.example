# Copy this to .env and fill in real values. NEVER commit .env to git.

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/supermatrix

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=change-me-in-production
CREDENTIALS_ENCRYPTION_KEY=change-me-fernet-base64-32bytes

# App
ENVIRONMENT=development
APP_NAME="SuperMatrix Data Extractor"
FRONTEND_URL=http://localhost:3000

# Google Ads MCC — get from Google Ads Manager → Admin → API Center
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_MCC_ID=

# Meta Ads — get from Meta Business Manager
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
